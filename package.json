{
  "name": "hitdash",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:client\" \"npm run dev:server\"",
    "dev:client": "vite",
    "dev:server": "node --env-file=.env --loader ts-node/esm --watch src/server/index.ts",
    "build": "npm run build:client && npm run build:server",
    "build:client": "vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "start": "node dist/server/index.js",
    "migrate": "node --env-file=.env --loader ts-node/esm src/agent/db/migrate.ts",
    "seed": "node --env-file=.env --loader ts-node/esm src/agent/scripts/seed-rag.ts",
    "test": "vitest",
    "test:coverage": "vitest --coverage"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.36.0",
    "@google/genai": "^0.7.0",
    "bullmq": "^5.0.0",
    "chart.js": "^4.5.1",
    "concurrently": "^9.0.0",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "express-rate-limit": "^8.3.2",
    "grammy": "^1.31.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.4.0",
    "pg": "^8.13.0",
    "pino": "^9.0.0",
    "pino-pretty": "^13.0.0",
    "rate-limit-redis": "^4.3.1",
    "vue": "^3.5.12",
    "vue-chartjs": "^5.3.3",
    "vue-router": "^4.4.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "@vitejs/plugin-vue": "^5.1.4",
    "@vitest/coverage-v8": "^2.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.0",
    "vite": "^5.4.10",
    "vitest": "^2.0.0"
  }
}
