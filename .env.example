# ═══════════════════════════════════════════════════════════════
# HITDASH — Variables de entorno
# Copiar a .env y completar — NUNCA commitear .env
# ═══════════════════════════════════════════════════════════════

# ─── PostgreSQL (contenedor hitdash-postgres) ─────────────────────
POSTGRES_USER=hitdash
POSTGRES_PASSWORD=           # ← generar: openssl rand -base64 32
POSTGRES_DB=hitdash

# ─── Redis (contenedor hitdash-redis) ────────────────────────────
REDIS_PASSWORD=              # ← generar: openssl rand -base64 24

# ─── Ballbot DB en Render (READ-ONLY) ───────────────────────────
# Render Dashboard → tu PostgreSQL de Ballbot → External Connection String
BALLBOT_DATABASE_URL=postgresql://user:pass@host.render.com:5432/ballbot

# ─── LLM APIs ───────────────────────────────────────────────────
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# ─── Telegram ───────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── App ────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001
